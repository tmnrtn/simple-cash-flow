# Copy this file to .env and adjust. docker compose reads .env automatically.
# .env is gitignored — never commit real secrets.

# --- Image version ----------------------------------------------------------
# Which published image tag to run (see docker-compose.yml). Pin to a release
# like 1.2.3 for stability; `latest` follows the newest release, `edge` follows
# main.
# IMAGE_TAG=latest

# --- Ports ------------------------------------------------------------------
# Host port for the web app (production nginx and the dev server both use 8080
# inside the container).
# WEB_PORT=8080

# Host port for the API. Only used in development (docker-compose.dev.yml) —
# in production the web container reverse-proxies /api and the API is not
# published to the host.
# API_PORT=3000

# --- Database ---------------------------------------------------------------
# POSTGRES_PASSWORD is REQUIRED — docker compose refuses to start without it.
# Use a strong value, e.g.:  openssl rand -hex 24
POSTGRES_PASSWORD=change-me
# POSTGRES_USER=postgres
# POSTGRES_DB=cashflow

# --- Authentication ---------------------------------------------------------
# Auth is ON by default. You must set a password and a secret, OR disable auth
# for a trusted private network. The API refuses to start if auth is enabled
# but unconfigured.

# Username for the single login account.
AUTH_USERNAME=admin

# The login password, in plaintext. Simplest option.
AUTH_PASSWORD=change-me

# Optional: supply a bcrypt hash instead of AUTH_PASSWORD (takes precedence).
# Generate one with:  node -e "console.log(require('bcryptjs').hashSync(process.argv[1],10))" 'your-password'
# AUTH_PASSWORD_HASH=

# Secret used to sign session cookies. Use a long random string, e.g.:
#   openssl rand -hex 32
AUTH_SECRET=

# Set to true to skip authentication entirely. Only for a trusted LAN — the API
# is fully open when this is on.
# AUTH_DISABLED=false

# --- Demo data --------------------------------------------------------------
# Set to true to seed a fictional demo dataset on the database's FIRST boot
# (ignored once the postgres_data volume already exists).
# DEMO_DATA=false
